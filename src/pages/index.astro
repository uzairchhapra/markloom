---
import PostCard from "@components/PostCard.astro";
import ProjectCard from "@components/ProjectCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { getProjects, getPublishedPosts } from "@core/content";
import { ArrowDownRight } from "@lucide/astro";

const [homeEntries, authors, experience] = await Promise.all([
  getCollection("home"),
  getCollection("authors"),
  getCollection("experience"),
]);
const [home] = homeEntries;
const [author] = authors;
const { Content } = home ? await render(home) : { Content: undefined };
const posts = (await getPublishedPosts()).slice(0, 3);
const projects = (await getProjects())
  .filter((project) => project.featured)
  .slice(0, 3);
const roles = experience.sort(
  (a, b) => b.data.startDate.getTime() - a.data.startDate.getTime(),
);

const year = (date?: Date) => date?.getUTCFullYear() ?? "Present";
---

<BaseLayout title={home?.data.title} description={home?.data.description}>
  <section class="hero section">
    <div class="section-inner hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">
          {home?.data.eyebrow ?? "Independent product engineer"}
        </p>
        <h1>{home?.data.title ?? "Markloom"}</h1>
        <p class="lede">
          {
            home?.data.description ??
              "Write content in Markdown. Configure behavior in YAML. Generate a polished static website."
          }
        </p>
        {
          home?.data.cta && (
            <a class="button" href={home.data.cta.href}>
              {home.data.cta.label}{" "}
              <ArrowDownRight size={15} aria-hidden="true" />
            </a>
          )
        }
      </div>
      <aside class="portfolio-note" aria-label="Current work">
        <p class="eyebrow">{home?.data.currentLabel ?? "Currently"}</p>
        <h2>{author?.data.role ?? "Product engineer"}</h2>
        <p>
          {
            author?.data.bio ??
              "Designing and building useful software with small, focused teams."
          }
        </p>
        <a href="#selected-work">Selected work ↓</a>
      </aside>
    </div>
  </section>
  {
    Content && (
      <section class="section section-compact">
        <div class="section-inner practice-intro">
          <p class="eyebrow">Approach</p>
          <div class="prose">
            <Content />
          </div>
        </div>
      </section>
    )
  }
  <section class="section" id="selected-work">
    <div class="section-inner">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Work / 01</p>
          <h2>Selected projects</h2>
        </div>
        <a class="section-link" href="/projects/">All projects →</a>
      </div>
      <div class="card-grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
  {
    roles.length > 0 && (
      <section class="section">
        <div class="section-inner">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Experience / 02</p>
              <h2>Where I’ve worked</h2>
            </div>
          </div>
          <ol class="experience-list">
            {roles.map((entry) => (
              <li class="experience-item">
                <p class="experience-dates">
                  {year(entry.data.startDate)}—{year(entry.data.endDate)}
                </p>
                <div>
                  <h3>{entry.data.role}</h3>
                  <p>{entry.data.organization}</p>
                  {entry.data.location && (
                    <p class="experience-location">{entry.data.location}</p>
                  )}
                </div>
                <ul class="experience-highlights">
                  {entry.data.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </li>
            ))}
          </ol>
        </div>
      </section>
    )
  }
  <section class="section">
    <div class="section-inner">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Notes / 03</p>
          <h2>Recent writing</h2>
        </div>
        <a class="section-link" href="/blog/">All writing →</a>
      </div>
      <div class="stack">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
</BaseLayout>
