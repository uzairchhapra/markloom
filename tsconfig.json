{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@config/*": ["src/config/*"],
      "@core/*": ["src/core/*"],
      "@layouts/*": ["src/layouts/*"],
      "@schema/*": ["src/schema/*"],
      "@themes/*": ["src/themes/*"],
      "@styles/*": ["src/styles/*"],
      "@utilities/*": ["src/utilities/*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": [
    ".astro/types.d.ts",
    "src",
    "tests",
    "scripts",
    "astro.config.mjs",
    "vitest.config.ts",
    "playwright.config.ts"
  ]
}
